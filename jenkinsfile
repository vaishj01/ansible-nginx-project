pipeline {
    agent any

    stages {

        stage('Clone Repository') {
            steps {
                checkout scm
            }
        }

        stage('Generate Password') {
            steps {
                sh './generate_password.sh'
            }
        }

        stage('Show Password') {
            steps {
                sh 'echo "Generated Password:"'
                sh 'cat roles/webserver/files/password.txt'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t wandernest-app:latest .'
            }
        }

        stage('Remove Old Container') {
            steps {
                sh 'docker rm -f wandernest || true'
            }
        }

        stage('Run Docker Container') {
            steps {
                sh 'docker run -d --name wandernest -p 9090:80 wandernest-app:latest'
            }
        }

        stage('Verify Deployment') {
            steps {
                sh 'docker ps'
                sh 'curl -I http://localhost:9090'
            }
        }
    }

    post {
        success {
            echo "Docker Deployment Successful!"
        }

        failure {
            echo "Deployment Failed!"
        }
    }
}